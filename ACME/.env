# Directory where all configuration will be stored
CONFIG=~/.blammo-cfg

# Exposed HTTP port
HTTP_PORT=80

# Exposed HTTPS port
HTTPS_PORT=443


# Internal XMPP domain
XMPP_DOMAIN=torino.illustra.tv

# Internal XMPP server
XMPP_SERVER=xmpp.torino.illustra.tv

# Internal XMPP server URL
XMPP_BOSH_URL_BASE=http://xmpp.torino.illustra.tv:5280

# Internal XMPP domain for authenticated services
XMPP_AUTH_DOMAIN=auth.torino.illustra.tv

# XMPP domain for the MUC
XMPP_MUC_DOMAIN=muc.torino.illustra.tv

# XMPP domain for the internal MUC used for jibri, jigasi and jvb pools
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.torino.illustra.tv



# Container restart policy
# Defaults to unless-stopped
RESTART_POLICY=unless-stopped

